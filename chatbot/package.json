{
  "name": "souarte-chatbot",
  "version": "1.0.0",
  "description": "Souarte Chatbot - WhatsApp Bot",
  "main": "main.js",
  "author": "Souarte",
  "scripts": {
    "dev": "concurrently --names \"backend,frontend\" --prefix-colors \"cyan,magenta\" \"pnpm --filter backend start\" \"pnpm --filter frontend dev\"",
    "postinstall": "electron-builder install-app-deps",
    "rebuild:backend-native": "electron-rebuild -f -w better-sqlite3 --module-dir backend",
    "electron:dev": "concurrently \"pnpm --filter backend start\" \"pnpm --filter frontend dev\" \"wait-on http://127.0.0.1:5173 && electron .\"",
    "electron:start": "electron .",
    "build:frontend": "pnpm --filter frontend build",
    "electron:build": "pnpm run build:frontend && pnpm run rebuild:backend-native && electron-builder",
    "electron:build:dir": "pnpm run build:frontend && pnpm run rebuild:backend-native && electron-builder --win dir",
    "electron:build:portable": "pnpm run build:frontend && pnpm run rebuild:backend-native && electron-builder --win portable"
  },
  "packageManager": "pnpm@10.33.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "puppeteer",
      "electron",
      "protobufjs",
      "@google/genai"
    ]
  },
  "build": {
    "appId": "com.souarte.chatbot",
    "productName": "Souarte Chatbot",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "main.js",
      "backend/**/*",
      "frontend/dist/**/*",
      "build/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "icon": "build/icon.ico",
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Souarte Chatbot"
    },
    "asar": false,
    "npmRebuild": true,
    "nodeGypRebuild": false,
    "buildDependenciesFromSource": false
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "concurrently": "^9.2.1",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "jimp": "^1.6.0",
    "wait-on": "^9.0.4"
  }
}